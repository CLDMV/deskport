{
	"name": "remote-dev-launcher",
	"displayName": "Remote Dev Launcher",
	"description": "Sync an SSH-remote workspace to your local machine and launch configured dev targets — for Electron and other GUI apps that must run where the display is.",
	"version": "0.2.0",
	"publisher": "cldmv",
	"icon": "resources/logo.png",
	"license": "SEE LICENSE IN LICENSE",
	"repository": {
		"type": "git",
		"url": "https://github.com/CLDMV/deskport.git"
	},
	"bugs": {
		"url": "https://github.com/CLDMV/deskport/issues"
	},
	"homepage": "https://github.com/CLDMV/deskport#readme",
	"engines": {
		"vscode": "^1.85.0"
	},
	"extensionKind": [
		"ui"
	],
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "remoteDevLauncher.menu",
				"title": "Targets…",
				"category": "Remote Dev Launcher"
			},
			{
				"command": "remoteDevLauncher.init",
				"title": "Initialize Project",
				"category": "Remote Dev Launcher"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p .configs/tsconfig.json",
		"package": "pnpm run compile && vsce package --no-dependencies -o remote-dev-launcher.vsix",
		"install-local": "pnpm run package && code --install-extension remote-dev-launcher.vsix --force",
		"publish": "pnpm run compile && vsce publish --no-dependencies"
	},
	"devDependencies": {
		"@types/node": "^22.13.5",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.2.1",
		"typescript": "^5.7.3"
	}
}
