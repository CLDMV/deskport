{
	"name": "deskport",
	"displayName": "DeskPort",
	"description": "Sync an SSH-remote workspace to your local machine and launch configured dev targets — for Electron and other GUI apps that must run where the display is.",
	"version": "0.8.2",
	"publisher": "cldmv",
	"icon": "resources/logo.png",
	"license": "Apache-2.0",
	"author": {
		"name": "Shinrai",
		"company": "CLDMV",
		"email": "git+npm@cldmv.net",
		"url": "https://cldmv.net"
	},
	"contributors": [
		{
			"name": "CLDMV",
			"url": "https://github.com/CLDMV"
		}
	],
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/shinrai"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/shinrai"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/CLDMV/deskport.git"
	},
	"bugs": {
		"url": "https://github.com/CLDMV/deskport/issues"
	},
	"homepage": "https://github.com/CLDMV/deskport#readme",
	"engines": {
		"vscode": "^1.85.0"
	},
	"extensionKind": [
		"ui"
	],
	"categories": [
		"Other"
	],
	"keywords": [
		"remote-ssh",
		"remote development",
		"electron",
		"launcher",
		"gui",
		"dev server",
		"monorepo"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "deskport.menu",
				"title": "Targets…",
				"category": "DeskPort"
			},
			{
				"command": "deskport.refresh",
				"title": "Refresh Targets",
				"category": "DeskPort",
				"icon": "$(refresh)"
			},
			{
				"command": "deskport.init",
				"title": "Initialize Project",
				"category": "DeskPort"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "deskport.refresh",
					"when": "view == deskport.targets",
					"group": "navigation"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "deskport",
					"title": "DeskPort",
					"icon": "resources/panel-icon.svg"
				}
			]
		},
		"views": {
			"deskport": [
				{
					"id": "deskport.targets",
					"name": "Targets",
					"type": "webview",
					"icon": "resources/panel-icon.svg"
				}
			]
		},
		"configuration": {
			"title": "DeskPort",
			"properties": {
				"deskport.clonePath": {
					"type": "string",
					"default": "",
					"scope": "window",
					"markdownDescription": "Base directory on the **local machine** where remote workspaces are mirrored (cloned). Each launch lands under `<clonePath>/<ssh-host>/<absolute-remote-path>/`, so the same remote folder always maps to the same local path regardless of which parent directory you opened in VSCode.\n\nLeave empty to use the default `~/.deskport-mirrors`. A leading `~` expands to your home directory. Because this is a local filesystem path, it can be set globally in **User** settings or overridden per project in **Workspace** settings."
				}
			}
		}
	},
	"scripts": {
		"compile": "tsc -p .configs/tsconfig.json",
		"package": "pnpm run compile && vsce package --no-dependencies -o deskport.vsix",
		"install-local": "pnpm run package && code --install-extension deskport.vsix --force",
		"publish": "pnpm run compile && vsce publish --no-dependencies"
	},
	"devDependencies": {
		"@types/node": "^22.13.5",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.2.1",
		"typescript": "^5.7.3"
	}
}
