# Source & tooling — never shipped
.configs/**
src/**
examples/**
docs/**
node_modules/**
**/*.map
**/tsconfig.json
.gitignore
.vscodeignore
pnpm-lock.yaml
deskport.vsix

# out/: ship only compiled JavaScript. Exclude everything, then allow *.js
# back in — so a stray file dropped in out/ can never leak into the package.
out/**
!out/**/*.js
